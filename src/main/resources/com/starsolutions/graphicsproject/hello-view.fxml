            <ToggleButton layoutX="10.0" layoutY="10.0" mnemonicParsing="false" prefHeight="80.0" prefWidth="105.0" selected="true" styleClass="boton-menu" text="Vivienda" toggleGroup="$groupLateralMenu" />
